{
  "name": "hame-relay",
  "version": "1.2.0",
  "description": "MQTT message forwarder between brokers",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "tsx src/main.ts",
    "test": "npm run build && node --test --import tsx/esm",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "lint": "prettier --check \"src/**/*.ts\"",
    "lint:fix": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "mqtt": "^5.15.1",
    "node-fetch": "^3.3.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3"
  }
}
